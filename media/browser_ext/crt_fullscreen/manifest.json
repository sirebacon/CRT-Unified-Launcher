{
  "manifest_version": 3,
  "name": "CRT Fullscreen Fix",
  "version": "1.7",
  "description": "Fixes video cropping in fullscreen on CRT displays. Network-level ad blocking via declarativeNetRequest.",
  "permissions": ["declarativeNetRequest"],
  "host_permissions": ["*://*/*"],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ad_block_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["*://*/*"],
      "css": ["style.css"],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}
